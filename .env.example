APP_NAME=Farros TikTok Bot
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=3200
APP_SECRET=change-me
APP_BASE_URL=http://localhost:3200

DATABASE_PATH=./storage/database/app.sqlite
TEMP_DIR=./storage/tmp
LOG_LEVEL=INFO

FARROS_WA_BASE_URL=https://wa.sangkolo.my.id
FARROS_WA_API_KEY=
FARROS_WA_WEBHOOK_SECRET=
FARROS_WA_SESSION_ID=

YT_DLP_BINARY=yt-dlp
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
TIKTOK_COOKIES_FILE=

MAX_MEDIA_MB=15
MAX_SOURCE_DOWNLOAD_MB=500
