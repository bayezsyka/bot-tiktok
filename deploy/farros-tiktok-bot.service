[Unit]
Description=Farros TikTok Bot - Production Ready WhatsApp & TikTok Gateway
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/farros-tiktok-bot
Environment="APP_ENV=production"
ExecStart=/var/www/farros-tiktok-bot/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 3200 --workers 1
Restart=always
RestartSec=5

# Security hardening
ProtectSystem=full
PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
